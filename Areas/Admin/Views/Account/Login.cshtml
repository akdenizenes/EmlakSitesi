@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Admin Giriş</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body { background: #0d1b3e; display: flex; align-items: center; justify-content: center; min-height: 100vh; }
        .login-card { max-width: 400px; width: 100%; border-radius: 16px; box-shadow: 0 10px 40px rgba(0,0,0,.3); }
        .btn-gold { background: #d4a942; color: #fff; font-weight: 600; }
        .btn-gold:hover { background: #b8912f; color: #fff; }
    </style>
</head>
<body>
    <div class="card login-card p-4">
        <h4 class="text-center mb-1" style="color:#0d1b3e;">Yönetim Paneli</h4>
        <p class="text-center text-muted mb-4">Devam etmek için giriş yapın</p>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger py-2">@ViewBag.Error</div>
        }

        <form method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label">Kullanıcı Adı</label>
                <input name="username" class="form-control" required autofocus />
            </div>
            <div class="mb-3">
                <label class="form-label">Şifre</label>
                <input name="password" type="password" class="form-control" required />
            </div>
            <button type="submit" class="btn btn-gold w-100">Giriş Yap</button>
        </form>
    </div>
</body>
</html>