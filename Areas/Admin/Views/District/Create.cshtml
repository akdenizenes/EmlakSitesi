@model EmlakSitesi.Models.Entities.District
@{
    ViewData["Title"] = "Yeni İlçe Ekle";
}

<div class="container py-4">
    <div class="card shadow-sm" style="max-width: 600px; margin: 0 auto;">
        <div class="card-header bg-success text-white">
            <h4 class="mb-0">📍 Yeni İlçe Ekle</h4>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post">
                
                <div class="mb-3">
                    <label class="form-label fw-bold">Bağlı Olduğu Şehir</label>
                    <!-- ViewBag.Cities ile gönderdiğimiz veriler burada liste oluyor -->
                    <select asp-for="CityId" class="form-select" asp-items="ViewBag.Cities" required>
                        <option value="">-- Şehir Seçin --</option>
                    </select>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">İlçe Adı</label>
                    <input asp-for="Name" class="form-control" placeholder="Örn: Kadıköy" required />
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4">Kaydet</button>
                    <a href="/Admin/District/Index" class="btn btn-secondary px-4">İptal</a>
                </div>

            </form>
        </div>
    </div>
</div>