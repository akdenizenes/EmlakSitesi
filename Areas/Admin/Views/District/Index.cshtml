@model IEnumerable<EmlakSitesi.Models.Entities.District>
@{
    ViewData["Title"] = "İlçeler";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>📍 İlçe Yönetimi</h2>
        <div>
            <a href="/Admin/Dashboard" class="btn btn-secondary me-2">Geri Dön</a>
            <a href="/Admin/District/Create" class="btn btn-success">+ Yeni İlçe Ekle</a>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Şehir</th>
                        <th>İlçe Adı</th>
                        <th class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <!-- Burada Include kullandığımız için Şehir adına ulaşabiliyoruz -->
                                <td><span class="badge bg-secondary">@item.City.Name</span></td>
                                <td>@item.Name</td>
                                <td class="text-end">
                                    <a href="/Admin/District/Delete/@item.Id" class="btn btn-sm btn-danger">Sil</a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="text-center text-muted py-3">Henüz hiç ilçe eklenmemiş.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>