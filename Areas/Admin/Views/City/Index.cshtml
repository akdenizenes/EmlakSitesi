@model IEnumerable<EmlakSitesi.Models.Entities.City>
@{
    ViewData["Title"] = "Şehirler";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>📍 Şehir Yönetimi</h2>
        <div>
            <a href="/Admin/Dashboard" class="btn btn-secondary me-2">Geri Dön</a>
            <a href="/Admin/City/Create" class="btn btn-success">+ Yeni Şehir Ekle</a>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Şehir Adı</th>
                        <th class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <!-- Modelinde Name veya Title ne yazıyorsa burayı ona göre güncelle -->
                                <td>@item.Name</td> 
                                <td class="text-end">
                                    <a href="/Admin/City/Delete/@item.Id" class="btn btn-sm btn-danger">Sil</a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="2" class="text-center text-muted py-3">Henüz hiç şehir eklenmemiş.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>