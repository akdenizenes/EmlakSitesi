@{
    Layout = null;
    ViewData["Title"] = "Panel";
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <title>Admin Panel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body class="bg-light">
    <div class="container py-5">
        
        <!-- Üst Başlık ve Çıkış -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3>Hoş geldin, @User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value 👋</h3>
            <a href="/admin/logout" class="btn btn-outline-danger">Çıkış Yap</a>
        </div>
        
        <!-- İstatistik Kartları -->
        <div class="row g-3">
            <div class="col-md-4">
                <div class="card p-4 text-center shadow-sm">
                    <h2>@ViewBag.PropertyCount</h2><span class="text-muted">Toplam İlan</span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card p-4 text-center shadow-sm">
                    <h2>@ViewBag.ActiveCount</h2><span class="text-muted">Aktif İlan</span>
                </div>
            </div>
        </div>

        <!-- Hızlı İşlemler Menüsü -->
        <div class="mt-5">
            <h4 class="mb-3 text-secondary">Hızlı İşlemler</h4>
            <div class="d-flex gap-3 flex-wrap">
                <a href="/Admin/Property" class="btn btn-primary px-4 py-2 shadow-sm">
                    🏠 İlanları Yönet
                </a>
                <a href="/Admin/City" class="btn btn-secondary px-4 py-2 shadow-sm">
                    📍 Konum Ayarları
                </a>
            </div>
        </div>

    </div>
</body>
</html>