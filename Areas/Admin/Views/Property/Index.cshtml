@model IEnumerable<EmlakSitesi.Models.Entities.Property>
@{
    ViewData["Title"] = "İlanlar";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>🏠 İlan Yönetimi</h2>
        <div>
            <a href="/Admin/Dashboard" class="btn btn-secondary me-2">Geri Dön</a>
            <a href="/Admin/Property/Create" class="btn btn-success">+ Yeni İlan Ekle</a>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>İlan Başlığı</th>
                        <th>Fiyat</th>
                        <th>Türü</th>
                        <th>Durum</th>
                        <th class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Title</td>
                                <td>@item.Price.ToString("N0") ₺</td>
                                <td>
                                    @if ((int)item.ListingType == 1)
                                    {
                                        <span class="badge bg-primary">Satılık</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">Kiralık</span>
                                    }
                                </td>
                                <td>
                                    @if(item.IsActive)
                                    {
                                        <span class="badge bg-success">Aktif</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Pasif</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <!-- İşte bahsettiğimiz butonlar burada, döngünün içinde! -->
                                    <a href="/Admin/Property/Images/@item.Id" class="btn btn-sm btn-info text-white">📷 Fotoğraflar</a>
                                    <a href="/Admin/Property/Edit/@item.Id" class="btn btn-sm btn-primary">Düzenle</a>
                                    <a href="/Admin/Property/Delete/@item.Id" class="btn btn-sm btn-danger" onclick="return confirm('Silmek istediğine emin misin?');">Sil</a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-3">Henüz hiç ilan eklenmemiş.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>