@model EmlakSitesi.Models.Entities.Property
@{
    ViewData["Title"] = "İlan Fotoğrafları";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4>📷 @Model.Title - Fotoğraflar</h4>
        <a href="/Admin/Property/Index" class="btn btn-secondary">İlan Listesine Dön</a>
    </div>

    <!-- Fotoğraf Yükleme Formu -->
    <div class="card shadow-sm mb-4 border-success">
        <div class="card-body bg-light">
            <!-- enctype="multipart/form-data" dosyaları göndermek için ZORUNLUDUR -->
            <form action="/Admin/Property/UploadImage" method="post" enctype="multipart/form-data" class="d-flex gap-3 align-items-end">
                <input type="hidden" name="propertyId" value="@Model.Id" />
                <div class="flex-grow-1">
                    <label class="form-label fw-bold">Bilgisayardan Yeni Fotoğraf(lar) Seç</label>
                    <!-- 'multiple' burada sihirli dokunuşu yapıyor -->
                    <input type="file" name="files" class="form-control" accept="image/*" multiple required />
                </div>
                <button type="submit" class="btn btn-success px-4">Yükle</button>
            </form>
        </div>
    </div>

    <!-- Yüklenen Fotoğraflar Galerisi -->
    <div class="row g-3">
        @if (Model.Images != null && Model.Images.Any())
        {
            @foreach (var img in Model.Images.OrderBy(i => i.SortOrder))
            {
                <div class="col-md-3">
                    <div class="card shadow-sm h-100">
                        <img src="@img.FilePath" class="card-img-top" alt="İlan Fotoğrafı" style="height: 200px; object-fit: cover;">
                        <div class="card-body text-center p-2">
                            <a href="/Admin/Property/DeleteImage/@img.Id" class="btn btn-sm btn-danger w-100" onclick="return confirm('Bu fotoğrafı tamamen silmek istediğinize emin misiniz?');">Sil</a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center text-muted py-5 border rounded bg-white">
                <p class="mb-0">Bu ilana henüz hiç fotoğraf eklenmemiş.</p>
            </div>
        }
    </div>
</div>